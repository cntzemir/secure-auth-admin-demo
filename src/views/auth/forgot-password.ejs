<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>
<main class="container narrow">
  <section class="card">
    <h1>Forgot password</h1>
    <form action="/forgot-password" method="POST" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        Email
        <input type="email" name="email" required>
      </label>
      <button type="submit" class="button">Record request</button>
    </form>
    <p class="muted">This is a mock flow that records a request and returns a generic response.</p>
  </section>
</main>
<%- include('../partials/footer') %>
